---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <slot />

    <script>
      import { gsap } from '../lib/gsap';

      function getHeaderOffset(): number {
        const root = document.documentElement;
        const raw = getComputedStyle(root).getPropertyValue('--header-h').trim();
        const parsed = parseInt(raw, 10);
        return Number.isFinite(parsed) ? parsed : 64;
      }

      function smoothScrollTo(target: Element | string) {
        const offset = getHeaderOffset();
        gsap.to(window, {
          duration: 0.9,
          ease: 'power3.inOut',
          scrollTo: { y: target, offsetY: offset, autoKill: false },
          overwrite: true,
        });
      }

      function onAnchorClick(e: MouseEvent) {
        // Skip if modifier keys (open-in-new-tab gestures)
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;

        const link = (e.target as HTMLElement | null)?.closest<HTMLAnchorElement>(
          'a[href^="#"]',
        );
        if (!link) return;
        const href = link.getAttribute('href');
        if (!href || href === '#') return;
        const id = href.slice(1);
        const target = document.getElementById(id);
        if (!target) return;

        // Capture phase + stopImmediatePropagation so Astro's ClientRouter
        // (also a document click listener) does not intercept and reload.
        e.preventDefault();
        e.stopImmediatePropagation();

        smoothScrollTo(target);
        history.replaceState(null, '', `#${id}`);
      }

      function bind() {
        document.removeEventListener('click', onAnchorClick, true);
        document.addEventListener('click', onAnchorClick, { capture: true });

        // Honor initial #hash on first paint
        if (location.hash.length > 1) {
          const t = document.getElementById(location.hash.slice(1));
          if (t) {
            requestAnimationFrame(() => smoothScrollTo(t));
          }
        }
      }

      bind();
      document.addEventListener('astro:page-load', bind);

      // Restore scroll position after language switch
      document.addEventListener('astro:after-swap', () => {
        const saved = sessionStorage.getItem('fnfbn:lang-scroll');
        if (saved !== null) {
          sessionStorage.removeItem('fnfbn:lang-scroll');
          const y = parseInt(saved, 10);
          if (Number.isFinite(y)) {
            window.scrollTo({ top: y, left: 0, behavior: 'instant' as ScrollBehavior });
          }
        }
      });
    </script>
  </body>
</html>
