---
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/strings';
import { pickLang, t } from '../i18n/strings';
import { getLocationsSection } from '../lib/singletons';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const section = await getLocationsSection();
const heading = pickLang(section.heading, locale) ?? '';
const labels = t(locale);

const all = await getCollection('locations');
const items = all
  .map((entry) => entry.data)
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
---

<section id="locations" class="locations">
  <div class="wrapper-outer">
    <header class="locations-heading">
      <h2 data-reveal>{heading}</h2>
    </header>

    {items.length > 0 && (
      <ul class="cards" data-reveal-group>
        {items.map((item) => {
          const title = pickLang(item.title, locale) ?? '';
          const date = pickLang(item.date, locale) ?? '';
          const time = pickLang(item.time, locale) ?? '';
          const url = item.routeUrl;
          return (
            <li class="card">
              <div class="card-upper">
                <h3 class="card-title">{title}</h3>
                <div class="card-meta">
                  {date && <p>{date}</p>}
                  {time && <p>{time}</p>}
                </div>
              </div>
              {url ? (
                <a class="card-cta" href={url} target="_blank" rel="noopener noreferrer">
                  <span>{labels.locations.routeTo}&nbsp;&nbsp;→</span>
                </a>
              ) : (
                <div class="card-cta card-cta--disabled" aria-hidden="true">
                  <span>{labels.locations.routeTo}&nbsp;&nbsp;→</span>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </div>
</section>

<style>
  .locations {
    background: var(--color-locations-bg);
    color: var(--color-fg);
    padding:
      clamp(48px, 6vw, 64px)
      var(--padding-section-h)
      clamp(48px, 8vw, 96px);
  }

  .wrapper-outer {
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 4vw, 48px);
    width: 100%;
  }

  .locations-heading {
    width: 100%;
    text-align: center;
  }
  .locations-heading h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.6vw, 36px);
    line-height: 1.1;
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-card-bg);
    border-radius: 4px;
    overflow: hidden;
  }

  .card-upper {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: center;
    flex: 1;
  }

  .card-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.1;
  }

  .card-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-size: 20px;
    line-height: 1.1;
    width: 100%;
  }
  .card-meta p {
    margin: 0;
    text-align: center;
  }

  .card-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px var(--space-5);
    background: var(--color-card-cta-bg);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1;
    text-decoration: none;
    transition: filter var(--dur-base) var(--ease-out);
  }
  a.card-cta:hover {
    filter: brightness(0.96);
  }
  .card-cta--disabled {
    opacity: 0.6;
    pointer-events: none;
  }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 960px) {
    .cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 640px) {
    .locations {
      padding:
        clamp(48px, 12vw, 64px)
        var(--padding-section-h-xs);
    }
    .locations-heading {
      text-align: left;
    }
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
