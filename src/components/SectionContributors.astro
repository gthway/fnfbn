---
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/strings';
import { pickLang, t } from '../i18n/strings';
import { getContributorsSection } from '../lib/singletons';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const section = await getContributorsSection();
const heading = pickLang(section.heading, locale) ?? '';
const labels = t(locale);

const ROLE_PRIORITY: Record<string, number> = {
  artist: 0,
  scientist: 1,
  organizer: 2,
};

function bucket(roles: readonly string[]): number {
  if (!roles.length) return 99;
  return Math.min(...roles.map((r) => ROLE_PRIORITY[r] ?? 99));
}

const all = await getCollection('contributors');
const items = all
  .map((entry) => entry.data)
  .sort((a, b) => {
    const ba = bucket(a.roles ?? []);
    const bb = bucket(b.roles ?? []);
    if (ba !== bb) return ba - bb;
    return (a.order ?? 0) - (b.order ?? 0);
  });
---

<section id="team" class="contributors">
  <header class="contributors-heading">
    <h2>{heading}</h2>
  </header>

  {items.length > 0 && (
    <ul class="cards">
      {items.map((item) => {
        const roleLabels = (item.roles ?? []).map((r) => labels.contributors.roles[r]);
        const initials = item.name
          .split(/\s+/)
          .map((w) => w[0])
          .join('')
          .slice(0, 2)
          .toUpperCase();
        return (
          <li class="card">
            <div class="card-upper">
              <div class="photo-frame">
                {item.photo ? (
                  <img src={item.photo} alt={item.name} loading="lazy" decoding="async" />
                ) : (
                  <span class="photo-initials" aria-hidden="true">{initials}</span>
                )}
              </div>
            </div>

            <div class="card-lower">
              <div class="card-text">
                <p class="card-name">{item.name}</p>
                {roleLabels.length > 0 && (
                  <ul class="tags">
                    {roleLabels.map((label) => (
                      <li class="tag">{label}</li>
                    ))}
                  </ul>
                )}
              </div>

              {item.link && (
                <a class="card-cta" href={item.link} target="_blank" rel="noopener noreferrer">
                  <span>{labels.contributors.visitWebsite}&nbsp;&nbsp;→</span>
                </a>
              )}
            </div>
          </li>
        );
      })}
    </ul>
  )}
</section>

<style>
  .contributors {
    background: var(--color-contributors-bg);
    color: var(--color-fg);
    padding:
      clamp(48px, 6vw, 64px)
      var(--padding-section-h)
      clamp(48px, 8vw, 96px);
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 4vw, 48px);
  }

  .contributors-heading {
    text-align: center;
  }
  .contributors-heading h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.6vw, 36px);
    line-height: 1.1;
  }

  .cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    grid-auto-rows: 1fr;
    gap: var(--space-5);
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-card-bg);
    border-radius: 4px;
    overflow: hidden;
    height: 100%;
  }

  .card-upper {
    padding: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-frame {
    width: clamp(120px, 14vw, 164px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--color-photo-placeholder);
    overflow: hidden;
    display: grid;
    place-content: center;
  }
  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo-initials {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    color: var(--color-fg);
    opacity: 0.4;
  }

  .card-lower {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: 0 0 var(--space-5);
    flex: 1;
    justify-content: center;
  }

  .card-name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.1;
    text-align: center;
  }

  .tags {
    list-style: none;
    margin: 0;
    padding: 0 var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }
  .tag {
    background: var(--color-tag-bg);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .card-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px var(--space-5);
    background: var(--color-card-cta-bg);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1;
    text-decoration: none;
    transition: filter var(--dur-base) var(--ease-out);
  }
  a.card-cta:hover {
    filter: brightness(0.96);
  }

  /* ── Mobile ──────────────────────────────── */
  @media (max-width: 480px) {
    .contributors {
      padding:
        clamp(48px, 12vw, 64px)
        var(--padding-section-h-xs);
    }
    /* Stack mode: cards fit their own content */
    .cards {
      grid-auto-rows: auto;
    }
    .card {
      height: auto;
    }
  }
</style>
