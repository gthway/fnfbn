---
import type { Locale } from '../i18n/strings';
import type { ContactData } from '../lib/singletons';
import { pickLang, t } from '../i18n/strings';

interface Props {
  locale: Locale;
  data: ContactData;
}

const { locale, data } = Astro.props;
const heading = pickLang(data.heading, locale) ?? '';
const intro = pickLang(data.intro, locale) ?? '';
const labels = t(locale);
---

<section id="contact" class="contact">
  <div class="contact-intro">
    <h2 class="contact-heading">{heading}</h2>
    <p class="contact-text">{intro}</p>
  </div>

  <div class="contact-form-wrap">
    <form
      class="contact-form"
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action={locale === 'de' ? '/?sent=1#contact' : '/en/?sent=1#contact'}
    >
      <input type="hidden" name="form-name" value="contact" />
      <p class="hp">
        <label>Bot? <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <div class="field">
        <textarea id="contact-message" name="message" rows={6} required></textarea>
        <label for="contact-message" class="field-label">{labels.contact.message}</label>
      </div>

      <div class="field">
        <input id="contact-email" name="email" type="email" autocomplete="email" required />
        <label for="contact-email" class="field-label">{labels.contact.email}</label>
      </div>

      <button type="submit" class="submit">{labels.contact.send}</button>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--color-contact-bg);
    color: var(--color-fg);
    padding:
      clamp(48px, 8vw, 96px)
      var(--padding-section-h);
    display: grid;
    grid-template-columns: 1fr 2fr;
    column-gap: clamp(24px, 3vw, 36px);
    row-gap: clamp(36px, 5vw, 48px);
    align-items: start;
  }

  .contact-intro {
    display: contents;
  }

  .contact-heading {
    margin: 0;
    grid-column: 1;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.1;
  }

  .contact-text {
    margin: 0;
    grid-column: 2;
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.8vw, 24px);
    line-height: 1.5;
    max-width: var(--measure-body);
  }

  .contact-form-wrap {
    grid-column: 2;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Honeypot — visually hidden but reachable for crawlers */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .field input,
  .field textarea {
    width: 100%;
    background: var(--color-input-bg);
    border: 0;
    border-radius: 4px;
    padding: 16px;
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.4;
    color: var(--color-fg);
    resize: vertical;
  }
  .field input { min-height: 50px; }
  .field textarea { min-height: 180px; }
  .field input:focus-visible,
  .field textarea:focus-visible {
    outline: 2px solid var(--color-fg);
    outline-offset: 2px;
  }

  .field-label {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1;
    color: var(--color-fg);
  }

  .submit {
    align-self: flex-start;
    background: var(--color-button-bg);
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: 24px;
    line-height: 1.2;
    padding: 16px 24px;
    border-radius: 4px;
    cursor: pointer;
    transition: filter var(--dur-base) var(--ease-out);
  }
  .submit:hover {
    filter: brightness(0.96);
  }
  .submit:focus-visible {
    outline: 2px solid var(--color-fg);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .contact {
      grid-template-columns: 1fr;
    }
    .contact-heading,
    .contact-text,
    .contact-form-wrap {
      grid-column: 1;
    }
  }

  @media (max-width: 640px) {
    .contact {
      padding:
        clamp(48px, 12vw, 64px)
        var(--padding-section-h-xs);
    }
    .submit {
      align-self: stretch;
      text-align: center;
    }
  }
</style>
